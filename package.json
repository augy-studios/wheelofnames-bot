{
  "name": "discordjs-sample-wheel-bot",
  "version": "1.0.0",
  "description": "Sample discord.js bot that uses the Wheel of Names API to generate spinning wheel animations.",
  "license": "MIT",
  "author": "Gunnar Omander <gunnar@gomander.dev>",
  "type": "module",
  "main": "main.ts",
  "scripts": {
    "start": "npm run deploy-commands & node --env-file=.env .",
    "dev": "node --env-file=.env --watch .",
    "deploy-commands": "node --env-file=.env deploy-commands.ts",
    "check-types": "tsc",
    "lint": "oxlint",
    "format": "oxfmt"
  },
  "dependencies": {
    "discord.js": "^14.26.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "oxfmt": "~0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">= 24"
  }
}
